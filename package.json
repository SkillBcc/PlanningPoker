{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "npm run test && vite build && esbuild server.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/server.cjs",
